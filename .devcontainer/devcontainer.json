{
	"name": "osrf/ros:jazzy-desktop-full",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"runArgs": [
		"--ipc=host",
		"--network=host",
		"--device=/dev/dri"
	],
	"workspaceMount": "source=${localWorkspaceFolder},target=/root/ros_ws/src/${localWorkspaceFolderBasename},type=bind",
	"workspaceFolder": "/root/ros_ws/src",
	"containerEnv": {
		// X11 / XWayland — rviz2 (Ogre/GLX) requires X11, not native Wayland
		"DISPLAY": "${localEnv:DISPLAY}",
		// Wayland display for Qt/GTK apps that do support it
		"WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
		"XDG_RUNTIME_DIR": "/tmp/runtime-root",
		// Force rviz2 (Qt) to use X11/xcb — Ogre's GLX backend needs it
		"QT_QPA_PLATFORM": "xcb",
		"GDK_BACKEND": "x11",
		// Software rendering fallback if GPU passthrough doesn't work
		"LIBGL_ALWAYS_SOFTWARE": "0",
		"MESA_GL_VERSION_OVERRIDE": "3.3"
	},
	"mounts": [
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/root/.ssh,readonly,type=bind",
		// Wayland socket
		{
			"source": "${localEnv:XDG_RUNTIME_DIR}/${localEnv:WAYLAND_DISPLAY}",
			"target": "/tmp/runtime-root/${localEnv:WAYLAND_DISPLAY}",
			"type": "bind"
		},
		// X11 / XWayland socket
		{
			"source": "/tmp/.X11-unix",
			"target": "/tmp/.X11-unix",
			"type": "bind"
		},
		// // X11 auth cookie
		// {
		// 	"source": "${localEnv:XAUTHORITY:-${localEnv:HOME}/.Xauthority}",
		// 	"target": "/root/.Xauthority",
		// 	"type": "bind"
		// }
	],
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"zsh": {
						"path": "/bin/zsh"
					}
				}
			},
			"extensions": [
				"mhutchie.git-graph",
				"ms-azuretools.vscode-docker",
				"llvm-vs-code-extensions.vscode-clangd",
				"twxs.cmake",
				"cschlosser.doxdocgen",
				"ms-vscode.makefile-tools",
				"yzhang.markdown-all-in-one",
				"rust-lang.rust-analyzer",
				"tamasfe.even-better-toml"
			]
		}
	},
	"features": {}
}